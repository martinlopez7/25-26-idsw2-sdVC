@startuml
title Diagrama de Secuencia - Iniciar Sesión (Spring Boot + React)

actor "Usuario (Docente/Admin)" as User
participant "Frontend (React)" as FE
participant "AuthController" as Controller
participant "AuthService" as Service
participant "UsuarioRepository" as Repo
participant "JwtTokenProvider" as JWT
database "Base de Datos (PostgreSQL)" as DB

User -> FE: Ingresa credenciales (username, password)
activate FE
FE -> Controller: POST /api/auth/login (LoginRequest)
activate Controller
Controller -> Service: authenticate(username, password)
activate Service
Service -> Repo: findByUsername(username)
activate Repo
Repo -> DB: SELECT * FROM usuarios WHERE username = ?
activate DB
DB --> Repo: Optional<Usuario>
deactivate DB
Repo --> Service: Optional<Usuario>
deactivate Repo
Service -> Service: passwordEncoder.matches(password, hash)
alt Credenciales Válidas
    Service -> JWT: generateToken(username, tipoActor)
    activate JWT
    JWT --> Service: String token
    deactivate JWT
    Service --> Controller: JwtResponse(token, "Bearer", tipoActor)
    Controller --> FE: 200 OK (JwtResponse)
    FE -> FE: Guardar Token (LocalStorage) y tipoActor
    FE --> User: Redirigir a Dashboard
else Credenciales Inválidas
    Service --> Controller: throw BadCredentialsException
    deactivate Service
    Controller --> FE: 401 Unauthorized
    deactivate Controller
    FE --> User: Mostrar Error "Credenciales inválidas"
end
deactivate FE

@enduml