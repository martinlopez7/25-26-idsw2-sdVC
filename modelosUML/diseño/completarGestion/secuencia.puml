@startuml completarGestion
title Diagrama de Secuencia - completarGestion() (Spring Boot + React)

actor "Usuario (Docente/Admin)" as User
participant "Frontend (React)" as FE
participant "AuthController" as Controller
participant "AuthService" as Service
participant "JwtTokenProvider" as JWT

User -> FE: Solicita completarGestion()
activate FE
activate User

FE -> Controller: GET /api/auth/menu\nAuthorization: Bearer <token>
activate Controller

Controller -> JWT: extractTipoActor(token)
activate JWT
JWT --> Controller: String tipoActor (DOCENTE | ADMINISTRADOR_INSTITUCIONAL)
deactivate JWT

Controller -> Service: obtenerOpcionesMenu(tipoActor)
activate Service

alt #LightBlue tipoActor = DOCENTE
    Service --> Controller: MenuDTO{opciones: [cerrarSesion, importarConfiguracionGlobal, exportarConfiguracionGlobal, gestionAlumnos, gestionGrados, gestionAsignaturas, gestionPreguntas, gestionRespuestas, gestionExamenes]}
else #LightGreen tipoActor = ADMINISTRADOR_INSTITUCIONAL
    Service --> Controller: MenuDTO{opciones: [cerrarSesion, gestionDocentes]}
end
deactivate Service

Controller --> FE: 200 OK + MenuDTO
deactivate Controller

loop Para cada opción del menú
    FE -> User: Mostrar opciones disponibles
    User -> FE: Selecciona opción
    FE -> User: Redirigir a caso de uso
end

deactivate FE
deactivate User

note right of FE
  El JWT se almacena en LocalStorage
  y se envía en cada petición autenticada
end note
@enduml